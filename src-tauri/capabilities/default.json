{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "fab"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPCONFIG/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$DESKTOP/**" }, { "path": "$DOCUMENT/**" }]
    },
    "core:window:allow-start-dragging",
    "core:window:allow-set-always-on-top",
    "process:allow-exit"
  ]
}
