{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SnapBar",
  "version": "0.1.1",
  "identifier": "com.snapbar.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SnapBar",
        "width": 800,
        "height": 100,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "alwaysOnTop": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "template": "wix-template.wxs"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
